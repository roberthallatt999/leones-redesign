# GitHub Secrets Template for leonescreamery
#
# USAGE:
#   1. Copy this file: cp .github/secrets.yaml.example .github/secrets.yaml
#   2. Fill in all values in secrets.yaml (NEVER commit that file — it is gitignored)
#   3. Run: bash .github/deploy-scripts/manage-secrets.sh
#
# REQUIRES: gh CLI (https://cli.github.com) + yq (brew install yq)
#
# SERVER SETUP (one-time, per environment):
#   1. Run scripts/migrate-staging-prepare.sh — generates the dedicated SSH deploy
#      key (~/.ssh/leones-dev-deploy) and prepares the directory structure on
#      leones-dev. Paste the printed private key into ssh.private_key below.
#   2. After the first GitHub Actions deploy succeeds, update the Forge nginx
#      site webroot to ${STAGE_BASE_PATH}/current.

ssh:
  # Paste the FULL private key generated by migrate-staging-prepare.sh
  # (~/.ssh/leones-dev-deploy on your laptop). The matching public key is
  # appended to ~/.ssh/authorized_keys on leones-dev by the same script.
  private_key: |
    -----BEGIN OPENSSH PRIVATE KEY-----
    YOUR_PRIVATE_KEY_CONTENT_HERE
    -----END OPENSSH PRIVATE KEY-----

deployment:
  # ----------------------------------------------------------------------------
  # PRODUCTION
  # ----------------------------------------------------------------------------
  # Production deploys are gated to workflow_dispatch only until staging is
  # proven. To enable auto-deploy on push to main, uncomment the push trigger
  # in .github/workflows/lc-production.yml.
  production:
    # SSH connection to the production Forge server
    PROD_SERVER_HOST: your-prod-forge-server-ip-or-hostname
    PROD_SERVER_USER: forge
    # PHP CLI path on the server. Verify with: php -v
    SERVER_PHP_PATH: php

    # Production database credentials (Forge → site → Database)
    PROD_DB_HOST: 127.0.0.1
    PROD_DB_USER: your_prod_db_username
    PROD_DB_PASS: your_prod_db_password
    PROD_DB_NAME: your_prod_db_name

    # Deployment root on the production server.
    # Structure: ${PROD_BASE_PATH}/releases/, shared/, current (symlink)
    # Forge nginx webroot must be set to: ${PROD_BASE_PATH}/current
    PROD_BASE_PATH: /home/forge/leonescreamery.com

  # ----------------------------------------------------------------------------
  # STAGING
  # ----------------------------------------------------------------------------
  staging:
    # SSH connection to the staging Forge server (leones-dev)
    SERVER_HOST: your-staging-forge-server-ip-or-hostname
    SERVER_USER: forge
    SERVER_PHP_PATH: php

    # Staging database credentials (Forge → site → Database)
    STAGE_DB_HOST: 127.0.0.1
    STAGE_DB_USER: your_stage_db_username
    STAGE_DB_PASS: your_stage_db_password
    STAGE_DB_NAME: your_stage_db_name

    # Deployment root on the staging server.
    # Forge nginx webroot must be set to: ${STAGE_BASE_PATH}/current
    STAGE_BASE_PATH: /home/forge/lc.digitaldesigns.dev
