# =============================================================================
# Security: Common
# (Added by ai-config — do not remove section header)
# =============================================================================

# =============================================================================
# Environment Variables
# Contains database credentials, API keys, and secrets
# =============================================================================
.env
.env.*
!.env.example
!.env.*.example
!.env.template
!.env.*.template

# =============================================================================
# Private Keys & Certificates
# =============================================================================
*.key
*.pem
*.p12
*.pfx
*.crt
*.cer
*.der
*.csr
*.jks
*.keystore
*.priv

# =============================================================================
# SSH Keys
# =============================================================================
.ssh/
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
id_dsa
id_ecdsa
known_hosts

# =============================================================================
# Credential Files
# =============================================================================
.netrc
.git-credentials
.htpasswd
.pypirc
.gitconfig

# Package manager auth tokens (contain registry credentials)
auth.json
.npmrc
.yarnrc
.pip/pip.conf

# =============================================================================
# Cloud Provider Credentials
# =============================================================================
# AWS
.aws/credentials
.aws/config
aws-credentials*
*_accessKeys.csv

# Google Cloud
gcloud/application_default_credentials.json
*-service-account*.json
service-account*.json
*-credentials.json
credentials.json

# Azure
.azure/

# Generic patterns
*_credentials.*
*_secret.*

# =============================================================================
# API Keys & Tokens
# =============================================================================
apikeys.*
api-keys.*
api_keys.*
*apikey*
*api-key*
*api_key*
*_token.*
*-token.*

# =============================================================================
# Secret & Vault Files
# =============================================================================
secrets.json
secrets.yml
secrets.yaml
*.secret
*.secrets
*.token
*.password
vault.yml
vault.yaml
*vault*.yml
*vault*.yaml

# =============================================================================
# Database Dumps (may contain real data)
# =============================================================================
*.sql.gz
*.sql.bz2
*.dump
db-dump.*
dump-*.sql
*-dump.sql

# =============================================================================
# Security: Custom
# (Added by ai-config — do not remove section header)
# =============================================================================

# =============================================================================
# Database Configuration (may contain credentials)
# =============================================================================
database.yml
database.yaml
database.json
db-config.*
*database-credentials*

# =============================================================================
# Logs (may contain sensitive runtime data and request details)
# =============================================================================
*.log
logs/
log/
npm-debug.log*
yarn-debug.log*

# =============================================================================
# Common Dependencies (never commit — install from lock file)
# =============================================================================
vendor/
!src/assets/scss/vendor/

# =============================================================================
# Addon-bundled vendor libraries — DO commit (deploys rsync git-tracked files
# only, so any addon-bundled dependency MUST be in git). Re-include the trees
# that the broad rules above (vendor/, log/, logs/) would otherwise hide.
# =============================================================================
!lcmin/user/addons/*/vendor/
!lcmin/user/addons/*/vendor/**
!lcmin/user/addons/*/vendor-build/
!lcmin/user/addons/*/vendor-build/**

# ...except dev-only tools that should not ship to production servers
lcmin/user/addons/*/vendor/bin/
lcmin/user/addons/*/vendor/phpstan/
lcmin/user/addons/*/vendor/phpunit/
lcmin/user/addons/*/vendor/rector/
lcmin/user/addons/**/*.phar

# Server migration playbook (per-operator local config + caches)
scripts/migrate-server.yaml
scripts/.migrate-logs/
scripts/.migrate-cache/
.github/secrets.yaml.pre-cutover-*
specs

# Webflow standalone preview — only ignore generated/installed dirs
webflow/node_modules
webflow/dist
